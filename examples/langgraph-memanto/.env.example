# Moorcheh API Key (required) - Get one at https://console.moorcheh.ai/api-keys
MOORCHEH_API_KEY=your_moorcheh_api_key_here

# OpenRouter API Key (for LangGraph LLM) - Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: Custom Memanto server URL (default: http://127.0.0.1:8000)
MEMANTO_SERVER_URL=http://127.0.0.1:8000

