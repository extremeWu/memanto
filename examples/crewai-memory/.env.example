# Moorcheh API Key (required)
# Get yours at: https://console.moorcheh.ai/api-keys
MOORCHEH_API_KEY=your_moorcheh_api_key_here

# OpenRouter API Key (required for CrewAI's LLM)
# Get yours at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: Override the LLM model used by CrewAI agents
# Default: openrouter/tencent/hy3-preview:free (free, supports tool calling)
# Other options: openrouter/openai/gpt-4o-mini, openrouter/anthropic/claude-sonnet-4
# CREWAI_LLM=openrouter/tencent/hy3-preview:free
